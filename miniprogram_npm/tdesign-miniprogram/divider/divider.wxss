@import "..\common\style\index.wxss";

.t-divider {
    border-color: var(--td-divider-color,var(--td-bg-color-component,var(--td-gray-color-3,#e7e7e7)));
    border-style: var(--td-divider-content-line-style,solid);
    border-width: 0;
    color: var(--td-divider-color,var(--td-bg-color-component,var(--td-gray-color-3,#e7e7e7)));
    display: -webkit-flex;
    display: flex
}

.t-divider::after,.t-divider::before {
    border: inherit;
    border-color: inherit;
    border-style: inherit;
    box-sizing: border-box;
    content: "";
    display: block;
    -webkit-flex: 1;
    flex: 1
}

.t-divider--horizontal {
    -webkit-align-items: center;
    align-items: center;
    margin: var(--td-divider-horizontal-margin,20rpx) 0
}

.t-divider--horizontal::after,.t-divider--horizontal::before {
    border-top-width: var(--td-divider-border-width,2rpx);
    -webkit-transform: scaleY(.5);
    transform: scaleY(.5);
    -webkit-transform-origin: center;
    transform-origin: center
}

.t-divider--horizontal .t-divider__content:not(:empty) {
    margin: 0 var(--td-divider-content-margin,var(--td-spacer-1,24rpx))
}

.t-divider--vertical {
    -webkit-flex-direction: column;
    flex-direction: column;
    height: 28rpx;
    margin: 0 var(--td-divider-vertical-margin,var(--td-spacer,16rpx))
}

.t-divider--vertical::after,.t-divider--vertical::before {
    border-left-width: var(--td-divider-border-width,2rpx);
    -webkit-transform: scaleX(.5);
    transform: scaleX(.5);
    -webkit-transform-origin: center;
    transform-origin: center
}

.t-divider--vertical-center {
    -webkit-align-items: center;
    align-items: center;
    height: 100%
}

.t-divider--dashed {
    border-style: dashed
}

.t-divider__content {
    color: var(--td-divider-content-color,var(--td-text-color-placeholder,var(--td-font-gray-3,rgba(0,0,0,.4))));
    font-size: var(--td-divider-content-font-size,var(--td-font-size-s,24rpx));
    line-height: var(--td-divider-content-line-height,40rpx)
}

.t-divider--left::before,.t-divider--right::after {
    max-width: 60rpx
}
