}

.info-filename {
    font-size: 26rpx;
    padding: 6rpx
}

.button-block {
    grid-gap: 16rpx;
    display: grid;
    grid-template-columns: repeat(2,1fr);
    padding: 12rpx 22rpx
}

.analysis-data-text-info {
    font-size: 32rpx
}

.analysis-data-text-error {
