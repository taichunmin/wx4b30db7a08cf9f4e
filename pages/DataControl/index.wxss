}

.external-view {
    margin-bottom: 4rpx;
    margin-top: 4rpx
}

.external-class {
    border-radius: 0!important
}

.btn_disabled {
    --td-cell-title-color: #acacac;
    --td-cell-description-color: #acacac;
    color: #acacac;
    pointer-events: none
}

.no-info {
    -webkit-align-items: center;
    align-items: center;
    color: gray;
    font-size: 26rpx;
    height: 84rpx
}

.data-head,.no-info {
    display: -webkit-flex;
    display: flex;
    -webkit-justify-content: center;
    justify-content: center
}

.data-head {
    border-bottom: 1px solid transparent;
    border-image: linear-gradient(180deg,transparent 50%,#e6e6e6 0) 0 0 100% 0;
    -webkit-flex-direction: column;
    flex-direction: column;
    height: 92rpx;
    width: 750rpx
}

.title {
    color: #404040;
    font-size: 26rpx;
    padding-left: 12rpx
}

.card-data-scroll {
    background-color: #fff;
    height: 100%;
    width: 100%
}

.card-data-scroll-data {
