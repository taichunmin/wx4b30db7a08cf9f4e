    flex-direction: column
}

.buttontouch {
    color: #888;
    height: 52rpx
}

.buttontouch-bottom,.buttontouch-top {
    border-bottom: 1rpx solid #cccccc30
}

.buttontouch-up {
    border-top: 1rpx solid #87ceeb50
}

.buttontouch-down,.buttontouch-up {
    border-radius: 100%;
    color: #00968880
}

.buttontouch-down {
    border-bottom: 1rpx solid #87ceeb50
}

.button-list-view,.data-auto-adaption {
    -webkit-flex: 1;
    flex: 1;
    overflow: scroll
}

.button-list-scroll {
    height: 100%;
