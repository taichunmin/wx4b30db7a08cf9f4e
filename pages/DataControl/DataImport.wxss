.directory {
    -webkit-align-items: center;
    align-items: center;
    display: -webkit-flex;
    display: flex;
    font-size: small;
    -webkit-justify-content: left;
    justify-content: left;
    padding: 8px;
    width: 100%
}

.hover-directory {
    background-color: #87ceeb50
}

.directory-info {
    -webkit-align-items: center;
    align-items: center;
    background-color: #f5f5f5;
    color: gray;
    display: -webkit-flex;
    display: flex;
    font-size: small;
    height: 32px;
    -webkit-justify-content: center;
    justify-content: center
}

.directory-icon {
    padding: 0 4px
}

.directory-item-after {
    background-color: #e3e3e3;
    height: 1px;
    left: 0;
    right: 0;
    -webkit-transform: scaleY(.5);
    transform: scaleY(.5)
}

.custom-tabs {
    --td-tab-nav-bg-color: #f5f5f5
}

.cardhubs-search {
    --td-search-square-radius: 0rpx;
    --td-search-bg-color: #fff
}

.search-btn {
    -webkit-align-items: center;
    align-items: center;
    background: #fff;
    color: #2874ff;
    font-size: 32rpx;
    height: 80rpx;
    width: 120rpx
}

.btn_link,.search-btn {
    display: -webkit-flex;
    display: flex;
    -webkit-justify-content: center;
    justify-content: center
}

.btn_link {
    padding-right: 24rpx;
    padding-top: 12rpx
}

.loading-info {
    padding-bottom: 24rpx
}

.cardHub-ntag-cell {
    --td-cell-bg-color: #00bfff33
}

.cardHub-id-cell {
    --td-cell-bg-color: #98f5ff33
}

.external-class {
    border-radius: 0!important
}

.btn-openmessage {
    padding: 64rpx 32rpx 0
}

.btn-clipboard {
    padding: 32rpx 32rpx 0
}

.btn {
    -webkit-align-items: center;
    align-items: center;
    color: #fff;
    display: -webkit-inline-flex;
    display: inline-flex;
    height: 100%;
    -webkit-justify-content: center;
    justify-content: center;
    width: 120rpx
}

.delete-btn {
    background-color: #e34d59
}
