.dialog {
    margin-top: 24rpx
}

.scroll-class {
    border: .5px solid #dcdcdc;
    border-radius: 12rpx;
    height: 340rpx
}

.external-class {
    font-family: monospace,Courier New,Courier;
    padding: 24rpx 32rpx!important;
    width: inherit;
    word-spacing: -4px
}

.info-bottom {
    color: #565656;
    display: -webkit-flex;
    display: flex;
    font-size: 28rpx;
    height: 32rpx;
    -webkit-justify-content: space-between;
    justify-content: space-between;
    padding-right: 64rpx;
    padding-top: 12rpx;
    text-align: end;
    width: 100%
}

.info-error {
    color: brown
}
